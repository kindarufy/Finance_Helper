# --- Telegram ---
BOT_TOKEN=your_telegram_bot_token_here

# --- Внутренняя безопасность ---
INTERNAL_API_KEY=change_me_internal_api_key
MINIAPP_SIGNING_SECRET=change_me_miniapp_signing_secret

# --- PostgreSQL ---
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=finance_db
POSTGRES_USER=finance_user
POSTGRES_PASSWORD=finance_pass

# --- URL внутренних сервисов на сервере ---
FINANCE_URL=http://127.0.0.1:8001
ANALYTICS_URL=http://127.0.0.1:8002
GATEWAY_URL=http://127.0.0.1:8000

# --- Порты сервисов ---
FINANCE_PORT=8001
ANALYTICS_PORT=8002
GATEWAY_PORT=8000

# --- Mini App ---
# Публичный HTTPS-адрес Mini App на домене.
MINIAPP_PUBLIC_URL=https://app.vakaflaka.ru/miniapp/app

# --- Загрузки бота ---
UPLOAD_DIR=/data/finance_helper_uploads

# --- Необязательные демо-данные ---
DEMO_TELEGRAM_ID=123456789
DEMO_TELEGRAM_USERNAME=demo_user
